# dependencies
node_modules/

# environment variables
.env

# real documents (sensitive) — DO NOT version
samples/*
!samples/README.md
# ...except the fictional demo samples (watermarked "DOCUMENTO FICTÍCIO")
!samples/laudo-ouro-EXEMPLO.png
!samples/laudo-ouro-EXEMPLO.invalido.png

# real AuPass documents (sensitive: CPF/CNPJ, coordinates) — DO NOT version
documentos-reais/*
!documentos-reais/README.md

# generated passports (contain personal/commercial data) — DO NOT version
out/*
# ...except the audit log, which MUST be versioned (auditability requirement)
!out/*.audit.json

# demo video assets (large binaries + embedded document) — DO NOT version
video/

# models / cache downloaded by QVAC
.qvac/
models/
*.gguf
*.onnx
*.bin

# logs and OS
*.log
.DS_Store

# API key (ElevenLabs) — NEVER version
.eleven_key
